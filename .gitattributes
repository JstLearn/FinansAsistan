# Auto detect text files and perform LF normalization
* text=auto

# PowerShell scripts should use CRLF (Windows line endings)
*.ps1 text eol=crlf

# Shell scripts should use LF (Unix line endings)
*.sh text eol=lf

# Batch files should use CRLF (Windows line endings)
*.bat text eol=crlf
*.cmd text eol=crlf

# YAML files should use LF (Unix line endings for Kubernetes compatibility)
*.yml text eol=lf
*.yaml text eol=lf

# JSON files should use LF (Unix line endings)
*.json text eol=lf

# Markdown files should use LF (Unix line endings)
*.md text eol=lf

# Source code files should use LF (Unix line endings)
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.py text eol=lf
*.java text eol=lf
*.go text eol=lf
*.rs text eol=lf

# Configuration files
*.env text eol=lf
*.config text eol=lf
*.conf text eol=lf

# SQL files should use LF (Unix line endings)
*.sql text eol=lf

# Docker files should use LF (Unix line endings)
Dockerfile text eol=lf
*.dockerfile text eol=lf
.dockerignore text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

