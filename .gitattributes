# Auto detect text files and perform LF normalization
* text=auto

# PowerShell scripts should use CRLF (Windows line endings)
*.ps1 text eol=crlf

# Shell scripts should use LF (Unix line endings)
*.sh text eol=lf

# Batch files should use CRLF (Windows line endings)
*.bat text eol=crlf
*.cmd text eol=crlf

# YAML files should use LF (Unix line endings for Kubernetes compatibility)
*.yml text eol=lf
*.yaml text eol=lf

# JSON files should use LF
*.json text eol=lf

# Markdown files should use LF
*.md text eol=lf

# JavaScript files should use LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# CSS files should use LF
*.css text eol=lf
*.scss text eol=lf

# HTML files should use LF
*.html text eol=lf

# Python files should use LF
*.py text eol=lf

# Terraform files should use LF
*.tf text eol=lf
*.tfvars text eol=lf

# SQL files should use LF
*.sql text eol=lf

# Configuration files should use LF
*.conf text eol=lf
*.config text eol=lf
*.ini text eol=lf
*.env text eol=lf

# Docker files should use LF
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Makefile should use LF
Makefile text eol=lf

# Lock files should use LF
*.lock text eol=lf
