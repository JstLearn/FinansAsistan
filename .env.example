# FinansAsistan - Production Environment
# Bu dosyayı .env olarak kopyala ve değerleri doldur

# PostgreSQL
POSTGRES_DB=finans_db
POSTGRES_USER=finans_user
POSTGRES_PASSWORD=zorlu_bir_sifre

# JWT
JWT_SECRET=guvenli_jwt_sifresi

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SSL=false
EMAIL_USER=
EMAIL_PASS=

# Cloudflare Tunnel (dinamik deploy için)
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
