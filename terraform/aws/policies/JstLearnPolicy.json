{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "MasterPolicyFullAccess",
            "Effect": "Allow",
            "Action": "*",
            "Resource": "*"
        },
        {
            "Sid": "DenyIAMUserDeletion",
            "Effect": "Deny",
            "Action": [
                "iam:DeleteUser",
                "iam:DeleteAccount"
            ],
            "Resource": "*"
        },
        {
            "Sid": "DenyRootAccountActions",
            "Effect": "Deny",
            "Action": [
                "iam:DeleteAccountPasswordPolicy",
                "iam:DeleteAccountAlias",
                "iam:UpdateAccountPasswordPolicy"
            ],
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "aws:RequestedRegion": "*"
                }
            }
        }
    ]
}

