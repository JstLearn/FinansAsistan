{
  "title": "FinansAsistan - Cluster Overview",
  "description": "Tüm node'larda container sayıları, servis durumları ve kaynak kullanımını gösterir",
  "tags": ["cluster", "nodes", "containers", "resources"],
  "timezone": "browser",
  "schemaVersion": 27,
  "version": 3,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Node Overview - CPU & Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}} - CPU %",
          "refId": "A"
        },
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{instance}} - Memory %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 2,
      "title": "Total Nodes",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 10},
      "targets": [
        {
          "expr": "count(up{job=\"node-exporter\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      },
      "options": {
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "Total Containers",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 10},
      "targets": [
        {
          "expr": "count(container_cpu_usage_seconds_total{id!=\"\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      },
      "options": {
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "title": "Unique Services",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 10},
      "targets": [
        {
          "expr": "count(count by (name) (container_cpu_usage_seconds_total{id!=\"\"}))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 1, "color": "green"}
            ]
          }
        }
      },
      "options": {
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 5,
      "title": "Average CPU Usage",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 10},
      "targets": [
        {
          "expr": "avg(rate(container_cpu_usage_seconds_total{id!=\"\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 50, "color": "yellow"},
              {"value": 80, "color": "red"}
            ]
          }
        }
      },
      "options": {
        "textMode": "value_and_name",
        "colorMode": "background"
      }
    },
    {
      "id": 6,
      "title": "Containers per Service",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "count by (name) (container_cpu_usage_seconds_total{id!=\"\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 7,
      "title": "CPU Usage by Container",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{id!=\"\"}[5m])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0
        }
      }
    },
    {
      "id": 8,
      "title": "Makine Listesi",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "node_uname_info",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "nodename"},
            "properties": [
              {"id": "displayName", "value": "Makine Adı"},
              {"id": "custom.width", "value": 200}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "instance"},
            "properties": [
              {"id": "displayName", "value": "Instance"},
              {"id": "custom.width", "value": 180}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "machine"},
            "properties": [
              {"id": "displayName", "value": "Makine ID"},
              {"id": "custom.width", "value": 150}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "release"},
            "properties": [
              {"id": "displayName", "value": "Kernel"},
              {"id": "custom.width", "value": 120}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"desc": false, "displayName": "Makine Adı"}]
      }
    },
    {
      "id": 11,
      "title": "Makine Kaynak Kullanımı",
      "type": "table",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 24},
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "count by (instance) (container_cpu_usage_seconds_total{id!=\"\", id!=\"/\", id!=\"/docker\"})",
          "format": "table",
          "instant": true,
          "refId": "D"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true
            },
            "indexByName": {
              "Makine": 0,
              "Toplam Memory": 1,
              "Kullanılabilir Memory": 2,
              "CPU %": 3,
              "Container Sayısı": 4
            },
            "renameByName": {
              "instance": "Makine",
              "Value #A": "Toplam Memory",
              "Value #B": "Kullanılabilir Memory",
              "Value #C": "CPU %",
              "Value #D": "Container Sayısı"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Makine"},
            "properties": [
              {"id": "custom.width", "value": 180}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Toplam Memory"},
            "properties": [
              {"id": "unit", "value": "bytes"},
              {"id": "custom.width", "value": 140}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Kullanılabilir Memory"},
            "properties": [
              {"id": "unit", "value": "bytes"},
              {"id": "custom.width", "value": 160}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "CPU %"},
            "properties": [
              {"id": "unit", "value": "percent"},
              {"id": "decimals", "value": 2},
              {"id": "custom.width", "value": 100},
              {"id": "color", "value": {"mode": "thresholds", "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 70, "color": "yellow"}, {"value": 90, "color": "red"}]}}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Container Sayısı"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "custom.width", "value": 120}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"desc": false, "displayName": "Makine"}]
      }
    },
    {
      "id": 12,
      "title": "Hiyerarşik Cluster Görünümü - Makine > Servis > Pod",
      "type": "table",
      "gridPos": {"h": 18, "w": 24, "x": 0, "y": 34},
      "targets": [
        {
          "expr": "label_replace(rate(container_cpu_usage_seconds_total{id!=\"\", id!=\"/\", id!=\"/docker\"}[5m]) * 100, \"pod_uid\", \"$1\", \"id\", \"/kubepods/kubepods/[^/]+/pod([^-]+-[^-]+-[^-]+-[^-]+-[^-]+)\")",
          "format": "table",
          "instant": true,
          "refId": "CPU"
        },
        {
          "expr": "label_replace(container_memory_usage_bytes{id!=\"\", id!=\"/\", id!=\"/docker\"} / 1024 / 1024, \"pod_uid\", \"$1\", \"id\", \"/kubepods/kubepods/[^/]+/pod([^-]+-[^-]+-[^-]+-[^-]+-[^-]+)\")",
          "format": "table",
          "instant": true,
          "refId": "Memory"
        },
        {
          "expr": "label_replace(time() - container_start_time_seconds{id!=\"\", id!=\"/\", id!=\"/docker\"}, \"pod_uid\", \"$1\", \"id\", \"/kubepods/kubepods/[^/]+/pod([^-]+-[^-]+-[^-]+-[^-]+-[^-]+)\")",
          "format": "table",
          "instant": true,
          "refId": "Age"
        },
        {
          "expr": "node_uname_info",
          "format": "table",
          "instant": true,
          "refId": "NodeInfo"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "machine": true,
              "release": true,
              "sysname": true,
              "version": true,
              "cpu": true
            },
            "indexByName": {
              "Makine": 0,
              "Servis": 1,
              "Pod": 2,
              "CPU %": 3,
              "Memory (MB)": 4,
              "Age": 5
            },
            "renameByName": {
              "instance": "Makine",
              "pod_uid": "Pod UID",
              "id": "Container ID",
              "Value #CPU": "CPU %",
              "Value #Memory": "Memory (MB)",
              "Value #Age": "Age",
              "nodename": "Makine Adı"
            }
          }
        },
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "instance"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "machine": true,
              "release": true,
              "sysname": true,
              "version": true,
              "cpu": true
            },
            "indexByName": {
              "Makine": 0,
              "Pod UID": 1,
              "Container ID": 2,
              "CPU %": 3,
              "Memory (MB)": 4,
              "Age": 5
            },
            "renameByName": {
              "instance": "Makine",
              "Pod UID": "Servis",
              "Container ID": "Pod"
            }
          }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "Makine": {
                "aggregations": [],
                "operation": "groupby"
              },
              "Servis": {
                "aggregations": [],
                "operation": "groupby"
              },
              "Pod": {
                "aggregations": [],
                "operation": "groupby"
              },
              "CPU %": {
                "aggregations": ["sum"],
                "operation": "aggregate"
              },
              "Memory (MB)": {
                "aggregations": ["sum"],
                "operation": "aggregate"
              },
              "Age": {
                "aggregations": ["max"],
                "operation": "aggregate"
              }
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "color-background",
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Makine"},
            "properties": [
              {"id": "custom.width", "value": 200},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "color", "value": {"mode": "palette-classic"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Servis"},
            "properties": [
              {"id": "custom.width", "value": 200},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}},
              {"id": "custom.displayMode", "value": "color-background"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Pod"},
            "properties": [
              {"id": "custom.width", "value": 200},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Container ID"},
            "properties": [
              {"id": "custom.width", "value": 300},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}},
              {"id": "displayName", "value": "Pod (Container ID)"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "CPU %"},
            "properties": [
              {"id": "unit", "value": "percent"},
              {"id": "decimals", "value": 2},
              {"id": "custom.width", "value": 100},
              {"id": "color", "value": {"mode": "thresholds", "thresholds": {"mode": "absolute", "steps": [{"value": 0, "color": "green"}, {"value": 50, "color": "yellow"}, {"value": 80, "color": "red"}]}}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Memory (MB)"},
            "properties": [
              {"id": "unit", "value": "decbytes"},
              {"id": "decimals", "value": 2},
              {"id": "custom.width", "value": 120}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Age"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "custom.width", "value": 100},
              {"id": "custom.displayMode", "value": "color-text"}
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"desc": false, "displayName": "Makine"}],
        "cellHeight": "sm"
      }
    },
    {
      "id": 9,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 48},
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{id!=\"\"}[5m])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0
        }
      }
    },
    {
      "id": 10,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 48},
      "targets": [
        {
          "expr": "sum by (name) (container_memory_usage_bytes{id!=\"\"}) / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "mbytes",
          "min": 0
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  }
}
