{
  "title": "FinansAsistan - Business Metrics",
    "tags": ["business", "metrics"],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "title": "Active Users",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "count(pg_stat_activity{datname=\"FinansAsistan\"})",
            "legendFormat": "Active Users"
          }
        ]
      },
      {
        "id": 2,
        "title": "Total Assets",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "SELECT COUNT(*) FROM varliklar",
            "rawSql": true,
            "format": "table"
          }
        ]
      },
      {
        "id": 3,
        "title": "Total Income",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "SELECT SUM(miktar) FROM gelir_alacak WHERE alindi_mi = false",
            "rawSql": true,
            "format": "table"
          }
        ]
      },
      {
        "id": 4,
        "title": "Total Expenses",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "SELECT SUM(miktar) FROM harcama_borc WHERE odendi_mi = false",
            "rawSql": true,
            "format": "table"
          }
        ]
      }
    ]
}

